<html>
<head>
<title>Summer Camp Registration Form</title>
</head>

<body>

<h2>Summer Camp Registration Form</h2>

<form action="#" method="post">

<label for="name">Name:</label>
<input type="text" id="name" name="name" required>
<br><br>

<label for="studentId">Student ID:</label>
<input type="text" id="studentId" name="studentId" required>
<br><br>

Gender:
<input type="radio" id="male" name="gender" value="male" required>
<label for="male">Male</label>

<input type="radio" id="female" name="gender" value="female">
<label for="female">Female</label>
<br><br>

Interests:
<input type="checkbox" id="swimming" name="interests" value="swimming">
<label for="swimming">Swimming</label>

<input type="checkbox" id="singing" name="interests" value="singing">
<label for="singing">Singing</label>

<input type="checkbox" id="dancing" name="interests" value="dancing">
<label for="dancing">Dancing</label>
<br><br>

<label for="remarks">Remarks:</label>
<br>
<textarea id="remarks" name="remarks" rows="4" cols="30"></textarea>
<br><br>

<button type="submit">Submit</button>

</form>

</body>
</html>
